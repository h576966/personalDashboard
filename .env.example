# Copy this file to .env.local and add your real API keys.
# Data is persisted in Supabase Postgres — no local database files.

# Brave Search API key — sign up at https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# DeepSeek API key — sign up at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Supabase project credentials — create a project at https://supabase.com
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_POSTGRES_PASSWORD=your_postgres_password_here
