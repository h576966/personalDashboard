# Copy this file to .env.local and add your real API keys.
# Data is persisted in Supabase Postgres — no local database files.

# Brave Search API key — sign up at https://brave.com/search/api/
BRAVE_API_KEY=your_brave_api_key_here

# DeepSeek API key — sign up at https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Supabase project credentials — create a project at https://supabase.com
# Public auth values are safe for browser use.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_publishable_or_anon_key_here
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_POSTGRES_PASSWORD=your_postgres_password_here

# Comma-separated emails allowed to use the shared Home household.
HOUSEHOLD_ALLOWED_EMAILS=person1@example.com,person2@example.com
